BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Salsa LA-Style//Website//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:Salsa LA-Style — Events
X-WR-CALDESC:Workshops and socials from Salsa LA-Style Copenhagen
X-WR-TIMEZONE:Europe/Copenhagen
REFRESH-INTERVAL;VALUE=DURATION:PT12H
X-PUBLISHED-TTL:PT12H
BEGIN:VTIMEZONE
TZID:Europe/Copenhagen
BEGIN:DAYLIGHT
TZOFFSETFROM:+0100
TZOFFSETTO:+0200
TZNAME:CEST
DTSTART:19700329T020000
RRULE:FREQ=YEARLY;BYMONTH=3;BYDAY=-1SU
END:DAYLIGHT
BEGIN:STANDARD
TZOFFSETFROM:+0200
TZOFFSETTO:+0100
TZNAME:CET
DTSTART:19701025T030000
RRULE:FREQ=YEARLY;BYMONTH=10;BYDAY=-1SU
END:STANDARD
END:VTIMEZONE
{% assign evs = site.events | sort: "date" -%}
{% for e in evs -%}
{% unless e.hidden %}{% include event_vevent.html event=e -%}
{% endunless -%}
{% endfor -%}
END:VCALENDAR
